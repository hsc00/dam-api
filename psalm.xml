<?xml version="1.0"?>
<psalm
    errorLevel="8"
    resolveFromConfigFile="true"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="vendor/vimeo/psalm/config.xsd"
    cacheDirectory=".psalm_cache"
    checkForThrowsDocblock="true"
    checkForThrowsInGlobalScope="true"
    findUnusedBaselineEntry="true"
    findUnusedCode="false"
>
    <projectFiles>
        <directory name="src"/>
        <ignoreFiles>
            <directory name="vendor"/>
        </ignoreFiles>
    </projectFiles>

    <!--
        Taint analysis: tracks user-controlled data (sources) to sensitive sinks
        (SQL queries, HTML output, shell commands) to detect injection vulnerabilities.
        Run with: vendor/bin/psalm - -taint-analysis
    -->
    <taintAnalysis>
        <ignoreFiles>
            <directory name="vendor"/>
        </ignoreFiles>
    </taintAnalysis>
</psalm>
