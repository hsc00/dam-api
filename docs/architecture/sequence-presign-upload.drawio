        <!-- Step 7: MockStorageAdapter → Application (return) -->
        <mxCell id="36" value="7. returns mock://uploads/{uploadId}  (no expiry)" style="edgeStyle=orthogonalEdgeStyle;endArrow=open;endFill=0;dashed=1;fontSize=10;html=1;" edge="1" parent="1">
