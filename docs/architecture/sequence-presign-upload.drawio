        </mxCell>

        <!-- Step 8: Application → MySQLAssetRepository -->
        <mxCell id="37" value="8. save(Asset{id, accountId, uploadId, status=uploading})" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;fontSize=10;html=1;" edge="1" parent="1">
