          <mxGeometry x="713" y="478" width="320" height="25" as="geometry" />
        </mxCell>

        <!-- Step 11: Application → GraphQL (return PresignResult) -->
        <mxCell id="41" value="11. PresignResult{uploadId, presignedUrl, expiresAt=null}" style="edgeStyle=orthogonalEdgeStyle;endArrow=open;endFill=0;dashed=1;fontSize=10;html=1;" edge="1" parent="1">
