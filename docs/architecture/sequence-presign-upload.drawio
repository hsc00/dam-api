        <mxCell id="50" value="&lt;b&gt;Examples&lt;/b&gt;&#xa;Valid file result: uploadId plus one chunk URL per piece&#xa;Rejected file result: errors explain duplicate identifier or invalid chunkCount&#xa;Top-level errors: empty batch or too many files" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontSize=10;fillColor=#f8f8f8;strokeColor=#aaaaaa;" vertex="1" parent="1">
