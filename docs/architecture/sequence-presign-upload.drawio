        <!-- Step 5: Application self — construct VO + Entity -->
        <mxCell id="34" value="5. new UploadId(uuid) + new Asset(uploading)" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="713" y="278" width="290" height="25" as="geometry" />
