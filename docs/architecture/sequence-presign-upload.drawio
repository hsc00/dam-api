        </mxCell>

        <mxCell id="51" value="&lt;b&gt;Note&lt;/b&gt;: MockStorageAdapter is still local-dev friendly, but the flow is now chunk-aware and batch-aware so the logic matches US-001a, US-001b, and US-006." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontSize=10;fillColor=#f8f8f8;strokeColor=#aaaaaa;" vertex="1" parent="1">
