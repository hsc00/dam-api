        <!-- Step 6: Application → MockStorageAdapter -->
        <mxCell id="35" value="6. generatePresignedUrl(uploadId, mimeType)" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;fontSize=10;html=1;" edge="1" parent="1">
