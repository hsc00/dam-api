        <!-- Step 12: GraphQL → Http -->
        <mxCell id="42" value='12. { data: { presignAsset: { uploadId, presignedUrl } } }' style="edgeStyle=orthogonalEdgeStyle;endArrow=open;endFill=0;dashed=1;fontSize=10;html=1;" edge="1" parent="1">
