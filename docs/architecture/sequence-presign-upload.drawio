        <!-- Step 1: Client → Http -->
        <mxCell id="30" value="1. mutation presignAsset(accountId, fileName, mimeType)" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;fontSize=10;html=1;" edge="1" parent="1">
          <mxGeometry x="100" y="155" as="geometry"><Array as="points"><mxPoint x="100" y="165" /><mxPoint x="290" y="165" /></Array></mxGeometry>
        </mxCell>

        <!-- Step 2: Http self — validate JWT -->
        <mxCell id="31" value="2. validate Bearer token → 401 if invalid" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="298" y="178" width="290" height="25" as="geometry" />
        </mxCell>

        <!-- Step 3: Http → GraphQL -->
        <mxCell id="32" value="3. dispatch to webonyx schema" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;fontSize=10;html=1;" edge="1" parent="1">
          <mxGeometry x="290" y="215" as="geometry"><Array as="points"><mxPoint x="290" y="225" /><mxPoint x="500" y="225" /></Array></mxGeometry>
        </mxCell>

        <!-- Step 4: GraphQL → Application -->
        <mxCell id="33" value="4. presign(PresignAssetCommand{accountId, fileName, mimeType})" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;fontSize=10;html=1;" edge="1" parent="1">
          <mxGeometry x="500" y="255" as="geometry"><Array as="points"><mxPoint x="500" y="265" /><mxPoint x="705" y="265" /></Array></mxGeometry>
