{
  "name": "dam/dam-php",
  "description": "DAM-style presign + status service — GraphQL + PHP 8.5 + MySQL",
  "type": "project",
  "require": {
    "php": "^8.5",
    "monolog/monolog": "^3.0",
    "ramsey/uuid": "^4.9",
    "vlucas/phpdotenv": "^5.6",
    "webonyx/graphql-php": "^15.32.2"
  },
  "require-dev": {
    "captainhook/captainhook": "^5.0",
    "friendsofphp/php-cs-fixer": "^3.0",
    "infection/infection": "^0.32",
    "phpstan/phpstan": "^1.0",
    "phpunit/phpunit": "^10.0",
    "roave/security-advisories": "dev-master",
    "squizlabs/php_codesniffer": "^3.0",
    "vimeo/psalm": "^6.0"
  },
  "conflict": {
    "webonyx/graphql-php": "<=15.31.4"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-install-cmd": "vendor/bin/captainhook install --force",
    "hooks:install": "vendor/bin/captainhook install --force",
    "test": "@php -d opcache.jit=0 -d xdebug.mode=off vendor/phpunit/phpunit/phpunit --no-coverage --configuration phpunit.xml --testsuite=unit",
    "test:integration": "@php -d opcache.jit=0 -d xdebug.mode=off vendor/phpunit/phpunit/phpunit --no-coverage --configuration phpunit.xml --testsuite=integration",
    "test:coverage": "@php -d opcache.jit=0 -d xdebug.mode=coverage vendor/phpunit/phpunit/phpunit --configuration phpunit.xml --testsuite=unit",
    "analyse": "@php -d opcache.jit=0 -d memory_limit=512M vendor/bin/phpstan analyse -c phpstan.neon --no-progress",
    "fix": "@php -d opcache.jit=0 vendor/bin/php-cs-fixer fix",
    "fix:check": "@php -d opcache.jit=0 vendor/bin/php-cs-fixer fix --dry-run --diff",
    "mutate": "vendor/bin/infection --configuration=infection.json5 --threads=max",
    "check": [
      "@fix:check",
      "@analyse"
    ],
    "ci": [
      "@fix:check",
      "@analyse",
      "@test"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "allow-plugins": {
      "infection/extension-installer": true
    }
  }
}
